[Unit]
Description=SPL Meter (FastAPI) on Raspberry Pi Zero 2W
After=network-online.target sound.target
Wants=network-online.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/PythonAkustik
Environment=PYTHONUNBUFFERED=1
ExecStart=/usr/bin/python3 -m uvicorn Presentation_1.code_base:app --host 0.0.0.0 --port=8000
Restart=on-failure
Nice=-10

[Install]
WantedBy=multi-user.target
